[Unit]
Description=Webhook Dispatcher — Tallos / RD Conversas
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/webhook-dispatcher
ExecStart=/opt/webhook-dispatcher/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=webhook-dispatcher

[Install]
WantedBy=multi-user.target
